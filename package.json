{
  "name": "@stratus-embeddings/compression",
  "version": "0.0.1",
  "description": "High-performance vector compression for embedding vectors. 10-20x compression with minimal quality loss.",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "stratus": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/cli.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "bench": "node benchmarks/run.js",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "embeddings",
    "compression",
    "vector",
    "quantization",
    "machine-learning",
    "ai",
    "openai",
    "semantic-search",
    "vector-database"
  ],
  "author": "Formation Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/formation/stratus.git",
    "directory": "sdk"
  },
  "bugs": {
    "url": "https://github.com/formation/stratus/issues"
  },
  "homepage": "https://github.com/formation/stratus#readme",
  "devDependencies": {
    "@types/node": "^20.10.0",
    "eslint": "^8.55.0",
    "prettier": "^3.1.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
