{
  "name": "@formthefog/stratus-sdk-ts",
  "version": "0.0.3",
  "description": "Stratus SDK - TypeScript client for the Stratus API with embedding compression utilities",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "assets"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "echo \"No linter configured\"",
    "format": "echo \"No formatter configured\""
  },
  "keywords": [
    "embeddings",
    "compression",
    "vector",
    "quantization",
    "machine-learning",
    "ai",
    "openai",
    "mjepa-g",
    "world-model",
    "trajectory-prediction",
    "semantic-search",
    "vector-database"
  ],
  "author": "Formation",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/formthefog/stratus-sdk-ts"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "^4.0.18",
    "typescript": "^5.3.0",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
